#!/usr/bin/env bash
# deepseek: launch Claude Code with DeepSeek as the backend.
#
# Generated by `make setup`. The ENV_FILE path below is baked in
# from the directory you ran `make setup` from. Re-run `make setup`
# if you move the project.

set -euo pipefail

ENV_FILE="@@ENV_FILE@@"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "deepseek: env file not found at $ENV_FILE" >&2
  echo "  re-run 'make setup' from the project root." >&2
  exit 1
fi

# Load KEY=VALUE pairs from the env file and auto-export them.
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

if [[ -z "${DEEPSEEK_API_KEY:-}" ]]; then
  echo "deepseek: DEEPSEEK_API_KEY is empty in $ENV_FILE" >&2
  echo "  edit the file and set DEEPSEEK_API_KEY=sk-..." >&2
  exit 1
fi

export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
export ANTHROPIC_AUTH_TOKEN="$DEEPSEEK_API_KEY"
export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-deepseek-v4-pro}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-deepseek-v4-pro}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-deepseek-v4-pro}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-deepseek-v4-flash}"
export CLAUDE_CODE_SUBAGENT_MODEL="${CLAUDE_CODE_SUBAGENT_MODEL:-deepseek-v4-flash}"
export CLAUDE_CODE_EFFORT_LEVEL="${CLAUDE_CODE_EFFORT_LEVEL:-max}"

# A stale ANTHROPIC_API_KEY in the environment would shadow AUTH_TOKEN.
unset ANTHROPIC_API_KEY

exec claude "$@"
